# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT_SECS=10
SERVER_WRITE_TIMEOUT_SECS=30

# Database
POSTGRES_DSN=postgres://helios:helios@localhost:5432/helios?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# AI Enrichment (optional — passthrough mode if unset)
GEMINI_API_KEY=your_gemini_api_key_here

# Ring buffer and worker pool
BUFFER_CAPACITY=4096
WORKER_COUNT=8
WORKER_MAX_CONCURRENT=32

# Rate limiting
RATELIMIT_RPS=100
RATELIMIT_BURST=200

# API auth (optional — disabled if unset)
AUTH_API_KEY=
